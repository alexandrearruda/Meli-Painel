# ============================================================
# Credenciais do app no Mercado Livre
# Crie em: https://developers.mercadolivre.com.br/devcenter
# ============================================================
MELI_CLIENT_ID=seu_app_id
MELI_CLIENT_SECRET=seu_client_secret

# Precisa ser EXATAMENTE igual ao "Redirect URI" cadastrado no app.
# Em desenvolvimento o ML aceita http://localhost.
MELI_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Domínio de autenticação. Use .com.br pra contas Brasil.
# (.com.ar Argentina, .com.mx México, etc.)
MELI_AUTH_DOMAIN=https://auth.mercadolivre.com.br

# ============================================================
# PostgreSQL
# ============================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/meli_painel
